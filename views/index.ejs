<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>mini message board</title>
</head>
<body>
    <h1>Mini Message Board</h1>
    <ul>
        <% messages.forEach((message) => {%>
            <%- include('message', {user: message.user, message: message.text, id: message.id}) %>
        <%});%>
    </ul>
    <a href="/new">Add new message</a>
</body>
</html>